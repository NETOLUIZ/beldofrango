/**
 * @file .env.example
 * @description Variáveis de ambiente de exemplo.
 * Copie este arquivo para .env e preencha com seus valores reais.
 */

# API
REACT_APP_API_URL=http://localhost:3000/api

# Autenticação
REACT_APP_AUTH_TOKEN_KEY=bdf_token
REACT_APP_SESSION_KEY=bdf_session

# Firebase (opcional, para push notifications)
REACT_APP_FIREBASE_API_KEY=
REACT_APP_FIREBASE_AUTH_DOMAIN=
REACT_APP_FIREBASE_PROJECT_ID=

# Modo desenvolvimento
REACT_APP_DEV_MODE=true
REACT_APP_LOG_LEVEL=debug
